{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pico Debug (RP2040)",
            "type": "cortex-debug",
            "request": "launch",

            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/app/app_main.elf",

            "servertype": "openocd",
            "device": "RP2040",

            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/rp2040.cfg"
            ],

            "serverArgs": [
                "-c", "adapter speed 5000"
            ],

            "postLaunchCommands": [
                "monitor reset halt"
            ],

            "runToEntryPoint": "main",

            "gdbPath": "C:/Users/mmadha/arm-gnu-toolchain-14.2.rel1-mingw-w64-i686-arm-none-eabi/bin/arm-none-eabi-gdb.exe",

            "svdFile": "H:/pico_sdk/src/rp2040/hardware_regs/rp2040.svd",

            "showDevDebugOutput": "raw"
        }
    ]
}
